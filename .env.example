# Copy to .env (gitignored). docker compose auto-loads this file.

# Public URL the server prints in upload responses.
PUBLIC_BASE=http://localhost:3000

# Host port to expose. Container always listens on 3000.
PORT=3000

# Max upload size in bytes (default 25 MB).
MAX_BYTES=26214400

# Where uploads and the SQLite DB live on the host.
# Defaults to ./data next to docker-compose.yml.
# STORAGE_DIR=/mnt/storage/tmpdrop
